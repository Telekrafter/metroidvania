  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041D\u0430\u0448\u0435 \u0434\u0435\u043B\u043E \u043D\u0435 \u0442\u0430\u043A
    \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E, \u043A\u0430\u043A
    \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F:
    \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u044B\u0439 \u043D\u0430\u043C\u0438
    \u0438\u043D\u043D\u043E\u0432\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0432\u044B\u0432\u043E\u0434\u0430 \u0442\u0435\u043A\u0443\u0449\u0438\u0445
    \u0430\u043A\u0442\u0438\u0432\u043E\u0432. \u0412\u043D\u0435\u0437\u0430\u043F\u043D\u043E,
    \u0430\u043A\u0446\u0438\u043E\u043D\u0435\u0440\u044B \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445
    \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0439 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043D\u0435 \u0447\u0442\u043E \u0438\u043D\u043E\u0435 "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
